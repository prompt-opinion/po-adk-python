# ── Required ───────────────────────────────────────────────────────────────────

# Google API key — used by google-adk to call Gemini
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here


# ── Optional: API keys for authenticated agents ───────────────────────────────

# Authenticated agents (healthcare_agent, orchestrator) require X-API-Key.
# You can provide one or more valid keys in either format below.

# Comma-separated format:
# API_KEYS=my-secret-key-1,my-secret-key-2

# Or named slots:
# API_KEY_PRIMARY=my-secret-key-1
# API_KEY_SECONDARY=my-secret-key-2


# ── Model provider ─────────────────────────────────────────────────────────────

# Set to FALSE to use your AI Studio API key (free Gemini quota).
# Set to TRUE only if you have a Vertex AI project and want to use it instead.
# Keeping this FALSE avoids Vertex AI billing entirely.
# GOOGLE_GENAI_USE_VERTEXAI=FALSE


# ── Model selection (per agent) ────────────────────────────────────────────────
# Each agent can independently use a native Gemini model or any LiteLLM-supported
# model. If not set, all agents default to gemini-2.5-flash.
#
# ── Gemini (native, default — only GOOGLE_API_KEY needed) ─────────────────────
# GENERAL_AGENT_MODEL=gemini-2.5-flash
# HEALTHCARE_AGENT_MODEL=gemini-2.5-flash
# ORCHESTRATOR_MODEL=gemini-2.5-flash
#
# ── OpenAI (requires OPENAI_API_KEY) ──────────────────────────────────────────
# GENERAL_AGENT_MODEL=openai/gpt-4o-mini
# HEALTHCARE_AGENT_MODEL=openai/gpt-4o-mini
# ORCHESTRATOR_MODEL=openai/gpt-4o-mini
#
# ── Anthropic Claude (requires ANTHROPIC_API_KEY) ─────────────────────────────
# GENERAL_AGENT_MODEL=anthropic/claude-3-5-sonnet-20241022
# HEALTHCARE_AGENT_MODEL=anthropic/claude-3-5-sonnet-20241022
# ORCHESTRATOR_MODEL=anthropic/claude-3-5-sonnet-20241022
#
# You can mix and match — e.g. orchestrator on Gemini, sub-agents on Claude.

# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here


# ── Optional: agent public URLs ────────────────────────────────────────────────
# Set these after deploying to Cloud Run so agent cards advertise the correct URL.
# Leave as defaults when running locally.

# HEALTHCARE_AGENT_URL=https://healthcare-agent-abc123-uc.a.run.app
# GENERAL_AGENT_URL=https://general-agent-abc123-uc.a.run.app
# ORCHESTRATOR_URL=https://orchestrator-abc123-uc.a.run.app

# ── Optional: Base URLs ────────────────────────────────────────────────────────
# If using a single tunnel like ngrok, define BASE_URL to have all agents use it.
# BASE_URL=https://my-agent.ngrok-free.app
# The base URL of your Prompt Opinion workspace (applies to FHIR extensions).
# PO_PLATFORM_BASE_URL=https://app.promptopinion.ai


# ── Optional: logging ──────────────────────────────────────────────────────────

# Log the full JSON-RPC request body on every incoming request (default: true)
# Set to false in production to reduce log volume
# LOG_FULL_PAYLOAD=true

# Dump the raw llm_request and callback_context objects before every LLM call.
# Useful when debugging a new metadata integration. (default: false)
# LOG_HOOK_RAW_OBJECTS=false
